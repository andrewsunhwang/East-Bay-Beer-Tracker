# Copy to .env and export, or set these in your process manager.

# Required for scraping (LLM parsing of brewery pages)
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED: the admin account. Only this email gets the Admin panel after
# signing in. There is no default — with this unset, admin features are
# disabled. Set it in your host's environment, not in the repo.
ADMIN_EMAIL=you@example.com

# Optional: lets the admin sign in with a password at /admin/login instead of
# an emailed code (handy if SMTP isn't set up yet, or you just prefer it).
# Set this only in your host's environment/secrets — never commit a real
# value here. Leave blank/unset to disable password login entirely.
ADMIN_PASSWORD=

# Public URL of the site (used in alert emails)
BASE_URL=http://localhost:8000

# Hour of day (server local time, 0-23) for the daily scrape
SCRAPE_HOUR=4

# SMTP — leave SMTP_HOST empty to print emails to the server log (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="East Bay Beer Tracker <no-reply@yourdomain.com>"

# Optional overrides
# SECRET_KEY=            # auto-generated & persisted in data/ if unset
# DB_PATH=data/beer_tracker.db
# CLAUDE_MODEL=claude-sonnet-5
